Package: buzzMed
Version: 0.1.2
Date: 2026-03-29
Title: Empirical Bayesian Mediation Analysis with Variable Selection
Authors@R: c(
    person("Dingjing", "Shi", email = "dshi32@gatech.edu", role = c("aut", "cre")),
    person("Tansu", "Celikel", role = "aut"),
