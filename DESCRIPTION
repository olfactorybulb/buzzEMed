Package: buzzMed
Version: 0.1.2
Date: 2026-03-17
Title: Bayesian Understanding of Mediation Selection in Exploratory
    Mediation Analysis
Authors@R: c(
    person("Chih-Chia", "Hsing", "jesscc.hsing@gmail.com", role = c("aut", "cre")),
    person("Dingjing", "Shi", "dshi32@gatech.edu", role = "aut"),
